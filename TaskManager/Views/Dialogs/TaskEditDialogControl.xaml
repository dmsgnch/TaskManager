<UserControl x:Class="TaskManager.Views.Dialogs.TaskEditDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="460">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0 0 0 20">
            <TextBlock x:Name="TitleTextBlock"
                       Text="{Binding Path=DialogTitle}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#202020" />

            <TextBlock Text="{Binding Path=[TaskDialogInstruction], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                       Margin="0 6 0 0"
                       FontSize="13"
                       Foreground="#707070"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding Path=[Title], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#707070" />

            <TextBox x:Name="TaskTitleTextBox"
                     Height="40"
                     Margin="0 6 0 0"
                     Padding="10 0"
                     Style="{StaticResource RoundedTextBoxWithPlaceholderStyle}"
                     Text="{Binding Path=TaskTitle,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged}"
                     Tag="{Binding Path=[TaskTitlePlaceholder], Mode=OneWay, Source={StaticResource LocalizationManager}}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Visibility="{Binding Path=ShowUserIdForm, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0 16 0 0">
            <TextBlock Text="{Binding Path=[UserId], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#707070" />

            <TextBox x:Name="UserIdTextBox"
                     Height="40"
                     Margin="0 6 0 0"
                     Padding="10 0"
                     Style="{StaticResource RoundedTextBoxWithPlaceholderStyle}"
                     Text="{Binding Path=UserIdText,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged}"
                     Tag="{Binding Path=[UserIdPlaceholder], Mode=OneWay, Source={StaticResource LocalizationManager}}" />
        </StackPanel>

        <CheckBox x:Name="IsCompletedCheckBox"
                  Grid.Row="3"
                  Margin="0 18 0 0"
                  Content="{Binding Path=[Completed], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                  FontSize="14"
                  Foreground="#202020"
                  IsChecked="{Binding Path=IsCompleted, Mode=TwoWay}" />

        <TextBlock x:Name="ErrorTextBlock"
                   Grid.Row="4"
                   Margin="0 14 0 0"
                   FontSize="13"
                   Foreground="#B3261E"
                   Text="{Binding Path=ErrorMessage}"
                   TextWrapping="Wrap"
                   Visibility="{Binding Path=ErrorMessage,
                                        Converter={StaticResource NotNullToVisibilityConverter}}" />

        <Grid Grid.Row="5"
              Margin="0 24 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Width="108"
                    Height="38"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderThickness="0"
                    Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding Path=ConfirmCommand}">
                <TextBlock Text="{Binding Path=[Confirm], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Button>

            <Button Grid.Column="2"
                    Width="108"
                    Height="38"
                    Margin="10 0 0 0"
                    Background="#F2F2F2"
                    Foreground="#202020"
                    BorderBrush="#DADADA"
                    BorderThickness="1"
                    Padding="0"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding Path=CancelCommand}">
                <TextBlock Text="{Binding Path=[Cancel], Mode=OneWay, Source={StaticResource LocalizationManager}}"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
