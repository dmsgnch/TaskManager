<UserControl x:Class="TaskManager.Views.Controls.UserControls.LoadingSpinnerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="48"
             Height="48">
    <Grid Width="48"
          Height="48"
          RenderTransformOrigin="0.5,0.5">

        <Grid.RenderTransform>
            <RotateTransform x:Name="SpinnerRotateTransform"
                             Angle="0" />
        </Grid.RenderTransform>

        <Path Stroke="{StaticResource AccentBrush}"
              StrokeThickness="4"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Data="M 24,7
                    A 17,17 0 1 1 13,37"
              Fill="Transparent" />

        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="SpinnerRotateTransform"
                                         Storyboard.TargetProperty="Angle"
                                         From="0"
                                         To="360"
                                         Duration="0:0:0.85" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>