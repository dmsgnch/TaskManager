<?xml version="1.0" encoding="utf-8"?>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- Glyphs -->

    <system:String x:Key="GlyphAdd">&#xE710;</system:String>
    <system:String x:Key="GlyphUpdate">&#xE777;</system:String>
    <system:String x:Key="GlyphSort">&#xE8CB;</system:String>
    <system:String x:Key="GlyphPerson">&#xE77B;</system:String>
    <system:String x:Key="GlyphArrowDown">&#xE70D;</system:String>
    <system:String x:Key="GlyphEdit">&#xE70F;</system:String>
    <system:String x:Key="GlyphClose">&#xE711;</system:String>
    <system:String x:Key="CheckGlyph">&#xE73E;</system:String>
    
    <!-- Glyphs fonts styles -->

    <Style x:Key="12FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="14FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="16FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="18FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="18" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="20FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="20" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="22FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="22" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <Style x:Key="24FluentNormalFontStyle"
           TargetType="TextBlock">
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontSize"
                Value="24" />
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeFluentIcons}" />
    </Style>

    <!-- Glyphs styles -->

    <Style x:Key="GlyphAddStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphAdd}" />
    </Style>

    <Style x:Key="GlyphUpdateStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphUpdate}" />
    </Style>

    <Style x:Key="GlyphSortStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphSort}" />
    </Style>

    <Style x:Key="GlyphPersonStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphPerson}" />
    </Style>

    <Style x:Key="GlyphArrowDownStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphArrowDown}" />
    </Style>

    <Style x:Key="GlyphEditStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphEdit}" />
    </Style>

    <Style x:Key="GlyphCloseStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource 16FluentNormalFontStyle}">
        <Setter Property="Text"
                Value="{StaticResource GlyphClose}" />
    </Style>

</ResourceDictionary>
